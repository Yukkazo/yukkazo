<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="create_line_to_pay_form" model="ir.ui.view">
            <field name="name">create_line_to_pay_form</field>
            <field name="model">create.line.to.pay</field>
            <field name="arch" type="xml">
                <form string="Line de pago">
                    <sheet>
                        <div class="oe_title">
                        </div>
                        <group>
                            <group>
                                <field name="suggested_amount_residual" readonly="1"/>
                                <field name="vat_retention"/>
                                <field name="amount_residual"/>
                                <field name="balance"/>
                                <field name="line_type"/>
                                <field name="account_id"/>
                                <field name="journal_id"/>
                            </group>
                            <group>
                                <field name="date"/>
                                <field name="date_maturity"/>
                                <field name="move_id"/>
                                <field name="ref"/>
                                <field name="name"/>
                            </group>
                            <footer>
                                <button string="Confirmar" class="btn-primary" type="object" name="add_account_move_line"/>
                                <button string="Cancelar" class="btn-secondary" special="cancel"/>
                            </footer>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="create_line_to_pay_wizard" model="ir.actions.act_window">
            <field name="name">Crear linea de pago</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">create.line.to.pay</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="create_line_to_pay_form"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>